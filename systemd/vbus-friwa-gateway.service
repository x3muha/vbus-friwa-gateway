[Unit]
Description=VBus FriWa Gateway
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=vbus-friwa
Group=dialout
WorkingDirectory=/opt/vbus-friwa-gateway
ExecStart=/usr/bin/node /opt/vbus-friwa-gateway/dist/index.js --config /etc/vbus-friwa-gateway/config.json
Restart=on-failure
RestartSec=10
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
